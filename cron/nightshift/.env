# Nightshift runtime config.
# launchd starts the wrapper every 20 minutes; the wrapper exits outside this window.
NIGHTSHIFT_ENABLED=true
NIGHTSHIFT_START=00:00
NIGHTSHIFT_END=08:00
NIGHTSHIFT_RETRY_FAILED=false
# Set true to skip runs when the target repo has local edits.
# Default false means Nightshift may commit and push pre-existing target-repo changes.
NIGHTSHIFT_REQUIRE_CLEAN_REPO=false
NIGHTSHIFT_REPO=/Users/max/projects/tockbot
NIGHTSHIFT_TASK_DIR=/Users/max/.agents/cron/nightshift/tasks
NIGHTSHIFT_PROGRESS=/Users/max/.agents/cron/nightshift/progress.md
NIGHTSHIFT_LOCK_DIR=/Users/max/.agents/cron/nightshift/.nightshift.lock
NIGHTSHIFT_LOG_DIR=/Users/max/.cron-logs/nightshift
NIGHTSHIFT_PI_THINKING=xhigh
