{
  "version": 1,
  "description": "Local source of truth for user-created launchd cron jobs.",
  "jobs": [
    {
      "id": "cleanup-processes",
      "label": "com.max.cleanup-processes",
      "group": "cleanup-processes",
      "description": "Kill stale orphaned user processes.",
      "script": "cleanup-processes/cleanup-processes.sh",
      "plist": "cleanup-processes/com.max.cleanup-processes.plist",
      "logs": ["~/Library/Logs/cleanup-processes.log"]
    },
    {
      "id": "nightshift",
      "label": "com.max.nightshift",
      "group": "nightshift",
      "description": "Run Nightshift review tasks back-to-back during the configured window.",
      "script": "nightshift/nightshift.sh",
      "plist": "nightshift/com.max.nightshift.plist",
      "logs": ["~/.cron-logs/nightshift.log", "~/.cron-logs/nightshift/*.log"]
    },
    {
      "id": "update-packages",
      "label": "com.max.update-packages",
      "group": "update-packages",
      "description": "Upgrade Homebrew and pnpm globals, then update the CLI inventory.",
      "script": "update-packages/update-packages.sh",
      "plist": "update-packages/com.max.update-packages.plist",
      "logs": ["~/Library/Logs/update-packages.log"]
    },
    {
      "id": "update-repos",
      "label": "com.max.update-repos",
      "group": "update-repos",
      "description": "Pull resource repositories and clean stale temporary git repos.",
      "script": "update-repos/update-repos.sh",
      "plist": "update-repos/com.max.update-repos.plist",
      "logs": ["~/.cron-logs/update-repos-*.log"]
    },
    {
      "id": "tailscale",
      "label": "com.max.tailscale",
      "group": "tailscale",
      "description": "Tailscale daemon in userspace-networking mode.",
      "script": "tailscale/tailscale.sh",
      "plist": "tailscale/com.max.tailscale.plist",
      "logs": ["~/Library/Logs/tailscale.log"]
    },
    {
      "id": "codex-relay",
      "label": "com.max.codex-relay",
      "group": "codex-relay",
      "description": "Persistent Codex Relay server for the mobile client.",
      "script": "codex-relay/codex-relay.sh",
      "plist": "codex-relay/com.max.codex-relay.plist",
      "logs": ["~/Library/Logs/codex-relay.log"]
    }
  ]
}
