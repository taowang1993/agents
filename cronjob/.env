# Night Shift configuration
# Edit this file to change agent, project, and timeout.

# Agent to use: "pi", "claude", or "codex" (default: pi)
NIGHT_SHIFT_AGENT=pi

# Project directory to run in
NIGHT_SHIFT_PROJECT=$HOME/projects/tockbot

# Timeout in minutes (uncomment to override default of 45)
# NIGHT_SHIFT_TIMEOUT=45
